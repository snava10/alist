{
  "name": "aguslist",
  "version": "2.2.2",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=development expo start --dev-client",
    "android": "expo run:android --device",
    "android-dev": "NODE_ENV=development expo run:android",
    "android-reload": "expo run:android",
    "ios": "expo run:ios --device",
    "ios-dev": "NODE_ENV=development expo run:ios --device",
    "web": "expo start --web",
    "build-production-android": "eas build --profile production --platform android",
    "build-development-android": "eas build --profile development --platform android",
    "build-development-ios": "eas build --profile development --platform ios",
    "build-production-ios": "eas build --profile production --platform ios",
    "firebase-emulator": "cd firebase-emulator && firebase emulators:start",
    "prebuild-clean": "npx expo prebuild --clean",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write '**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md}'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky install"
  },
  "dependencies": {
    "@expo/config-plugins": "~55.0.7",
    "@expo/metro-runtime": "~55.0.6",
    "@invertase/react-native-apple-authentication": "^2.4.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/cli-server-api": "^15.0.1",
    "@react-native-firebase/analytics": "^21.3.0",
    "@react-native-firebase/app": "^21.3.0",
    "@react-native-firebase/auth": "^21.3.0",
    "@react-native-firebase/firestore": "^21.3.0",
    "@react-native-google-signin/google-signin": "^13.1.0",
    "@react-native/js-polyfills": "^0.76.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@types/react-native-base64": "^0.2.2",
    "base-64": "^1.0.0",
    "expo": "~55.0.6",
    "expo-apple-authentication": "~55.0.9",
    "expo-auth-session": "~55.0.9",
    "expo-build-properties": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.18",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.10",
    "expo-updates": "~55.0.15",
    "expo-web-browser": "~55.0.10",
    "metro-source-map": "^0.81.0",
    "node-forge": "^1.3.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-native": "0.83.2",
    "react-native-base64": "^0.2.1",
    "react-native-dotenv": "^3.4.11",
    "react-native-dropdown-picker": "^5.4.6",
    "react-native-modal": "^13.0.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/base-64": "^1",
    "@types/jest": "^29.5.14",
    "@types/node-forge": "^1.3.14",
    "@types/react": "~19.2.10",
    "@types/react-native-vector-icons": "^6.4.18",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.1.1",
    "typescript": "~5.9.2"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
