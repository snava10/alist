{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.schema.json",
  "mutate": [
    "component/**/*.ts",
    "component/**/*.tsx",
    "!component/**/__tests__/**",
    "!component/**/*.test.{ts,tsx}",
    "!component/**/*.spec.{ts,tsx}",
    "!component/**/index.ts"
  ],
  "testRunner": "jest",
  "jest": {
    "configFile": "jest.config.cjs"
  },
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.stryker.json",
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/mutation-report.html"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 30
  },
  "concurrency": 4,
  "timeoutMS": 60000,
  "tempDirName": ".stryker-tmp",
  "ignorePatterns": [
    "ios",
    "android",
    "coverage",
    ".expo",
    "assets",
    "firebase-emulator",
    "plugins",
    ".stryker-tmp",
    "reports",
    "*.xcodeproj",
    "*.xcworkspace"
  ],
  "disableTypeChecks": "component/**/*.{ts,tsx}"
}
